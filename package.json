{
    "name": "@plurnk/plurnk-execs-jq",
    "version": "0.1.9",
    "description": "jq runtime executor for plurnk-service's exec scheme — shells the system jq binary to filter/transform JSON for EXEC[jq].",
    "keywords": [
        "plurnk",
        "exec",
        "runtime",
        "executor",
        "jq",
        "json",
        "filter"
    ],
    "homepage": "https://github.com/plurnk/plurnk-execs-jq#readme",
    "bugs": {
        "url": "https://github.com/plurnk/plurnk-execs-jq/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/plurnk/plurnk-execs-jq.git"
    },
    "engines": {
        "node": ">=26"
    },
    "license": "MIT",
    "author": "@wikitopian",
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "plurnk": {
        "kind": "exec",
        "runtimes": [
            {
                "name": "jq",
                "glyph": "🧰",
                "example": "<<EXEC[jq]:[1,2,3] | add:EXEC"
            }
        ]
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**/*",
        "README.md"
    ],
    "scripts": {
        "test:lint": "tsc --noEmit",
        "test:unit": "node --test \"src/**/*.test.ts\"",
        "test": "npm run test:lint && npm run test:unit",
        "build:dist": "tsc -p tsconfig.build.json",
        "build": "npm run build:dist",
        "prepare": "npm run build"
    },
    "devDependencies": {
        "@types/node": "^26.0.0",
        "typescript": "^6.0.3",
        "@plurnk/plurnk-execs": "^0.4.26"
    },
    "peerDependencies": {
        "@plurnk/plurnk-execs": "^0.4.26"
    }
}
